---
import '../styles/navbar.css';

const navLinks = [
  { href: '/blog', label: 'Blog' },
  { href: '/art', label: 'Art' },
  { href: '/projects', label: 'Projects' },
  { href: '/newsletter', label: 'Newsletter' },
  { href: '/about', label: 'About' },
];

const currentPath = Astro.url.pathname;
---

<nav class="navbar" id="navbar">
  <a href="/" class="navbar__logo">PHILO LI</a>

  <ul class="navbar__links">
    {navLinks.map(link => (
      <li>
        <a
          href={link.href}
          class:list={['navbar__link', { active: currentPath.startsWith(link.href) }]}
        >
          {link.label}
        </a>
      </li>
    ))}
  </ul>

  <button class="navbar__hamburger" id="hamburger" aria-label="Toggle menu">
    <span></span>
    <span></span>
    <span></span>
  </button>

  <ul class="navbar__mobile-menu" id="mobile-menu">
    {navLinks.map(link => (
      <li><a href={link.href}>{link.label}</a></li>
    ))}
  </ul>
</nav>

<script>
  const navbar = document.getElementById('navbar')!;
  const hamburger = document.getElementById('hamburger')!;
  const mobileMenu = document.getElementById('mobile-menu')!;

  window.addEventListener('scroll', () => {
    navbar.classList.toggle('scrolled', window.scrollY > 100);
  });

  hamburger.addEventListener('click', () => {
    mobileMenu.classList.toggle('open');
  });
</script>
