---
import '../styles/hero.css';

interface Props {
  backgroundImage?: string;
}

const { backgroundImage = '/images/hero.jpg' } = Astro.props;
---

<section class="hero">
  <div class="hero__bg" style={`background-image: url('${backgroundImage}')`}></div>
  <div class="hero__overlay"></div>
  <div class="hero__content">
    <h1 class="hero__name">Philo Li</h1>
    <p class="hero__tagline">I paint, photograph, write, and build things.</p>
  </div>
</section>
