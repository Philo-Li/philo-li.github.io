---
import SocialLinks from './SocialLinks.astro';
---

<footer class="footer">
  <div class="footer__inner">
    <div class="footer__newsletter">
      <span class="footer__newsletter-text">Stay in touch →</span>
      <a href="/newsletter" class="footer__newsletter-link">Subscribe</a>
    </div>
    <SocialLinks size="sm" />
    <p class="footer__copy">&copy; {new Date().getFullYear()} Philo Li. All rights reserved.</p>
  </div>
</footer>

<style>
  .footer {
    border-top: 1px solid var(--color-border);
    padding: var(--space-lg) var(--space-md);
    text-align: center;
  }
  .footer__inner {
    max-width: var(--max-width);
    margin: 0 auto;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: var(--space-sm);
  }
  .footer__newsletter {
    display: flex;
    align-items: center;
    gap: var(--space-sm);
    margin-bottom: var(--space-xs);
  }
  .footer__newsletter-text {
    color: var(--color-text-muted);
    font-size: 0.8rem;
  }
  .footer__newsletter-link {
    color: var(--color-accent);
    font-size: 0.8rem;
    font-weight: 500;
  }
  .footer__newsletter-link:hover {
    color: var(--color-accent-hover);
  }
  .footer__copy {
    color: var(--color-text-muted);
    font-size: 0.75rem;
  }
</style>
